{% extends 'base.html.twig' %}

{% block title %}Reservations for {{ event.title }}{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
        <li class="breadcrumb-item active">Reservations: {{ event.title }}</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-1">{{ event.title }}</h1>
        <p class="text-muted mb-0">
            <i class="bi bi-calendar3"></i> {{ event.date|date('d M Y, H:i') }} &mdash;
            <i class="bi bi-geo-alt"></i> {{ event.location }}
        </p>
    </div>
    <div class="text-end">
        <span class="badge bg-primary fs-6">{{ reservations|length }} / {{ event.seats }} booked</span>
    </div>
</div>

{% if reservations is empty %}
<div class="text-center text-muted py-5">
    <i class="bi bi-ticket-x" style="font-size:3rem;"></i>
    <p class="mt-3">No reservations yet for this event.</p>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Booked On</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for res in reservations %}
                <tr>
                    <td><code>#{{ res.id }}</code></td>
                    <td class="fw-semibold">{{ res.name }}</td>
                    <td>{{ res.email }}</td>
                    <td>{{ res.phone ?? '-' }}</td>
                    <td>{{ res.createdAt|date('d M Y, H:i') }}</td>
                    <td>
                        <form method="post" action="{{ path('app_admin_reservation_delete', {'id': res.id}) }}"
                              onsubmit="return confirm('Delete this reservation?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_res_' ~ res.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
