{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - EventReserve{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold"><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
    <a href="{{ path('app_admin_event_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Event
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4">
            <i class="bi bi-calendar-event text-primary" style="font-size:2.5rem;"></i>
            <h3 class="fw-bold mt-2">{{ events|length }}</h3>
            <p class="text-muted mb-0">Total Events</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4">
            <i class="bi bi-ticket text-success" style="font-size:2.5rem;"></i>
            <h3 class="fw-bold mt-2">
                {% set total = 0 %}
                {% for e in events %}{% set total = total + e.reservations|length %}{% endfor %}
                {{ total }}
            </h3>
            <p class="text-muted mb-0">Total Reservations</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4">
            <i class="bi bi-people text-warning" style="font-size:2.5rem;"></i>
            <h3 class="fw-bold mt-2">
                {% set avail = 0 %}
                {% for e in events %}{% set avail = avail + e.availableSeats %}{% endfor %}
                {{ avail }}
            </h3>
            <p class="text-muted mb-0">Seats Available</p>
        </div>
    </div>
</div>

{% if events is empty %}
<div class="text-center text-muted py-5">
    <i class="bi bi-calendar-x" style="font-size:3rem;"></i>
    <p class="mt-3">No events yet. <a href="{{ path('app_admin_event_new') }}">Create one!</a></p>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Location</th>
                    <th>Seats</th>
                    <th>Reservations</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for event in events %}
                <tr>
                    <td>{{ event.id }}</td>
                    <td class="fw-semibold">{{ event.title }}</td>
                    <td>{{ event.date|date('d M Y, H:i') }}</td>
                    <td>{{ event.location }}</td>
                    <td>{{ event.seats }}</td>
                    <td>
                        <a href="{{ path('app_admin_event_reservations', {'id': event.id}) }}" class="badge bg-primary text-decoration-none">
                            {{ event.reservations|length }} reserved
                        </a>
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-outline-info" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('app_admin_event_edit', {'id': event.id}) }}" class="btn btn-outline-warning" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('app_admin_event_delete', {'id': event.id}) }}"
                                  onsubmit="return confirm('Delete this event?');" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                                <button type="submit" class="btn btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
