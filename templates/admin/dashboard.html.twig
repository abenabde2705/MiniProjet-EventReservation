{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - EventReserve{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-zinc-900">Admin Dashboard</h1>
        <p class="text-sm text-zinc-500 mt-1">Manage events and reservations</p>
    </div>
    <a href="{{ path('app_admin_event_new') }}"
       class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700 transition-colors shadow-sm">
        <i class="bi bi-plus-lg"></i> New Event
    </a>
</div>

{# Stats #}
{% set total_reservations = 0 %}
{% set total_available = 0 %}
{% for e in events %}
    {% set total_reservations = total_reservations + e.reservations|length %}
    {% set total_available = total_available + e.availableSeats %}
{% endfor %}

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="rounded-xl border border-zinc-200 bg-white shadow-sm p-5 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-indigo-100 flex items-center justify-center shrink-0">
            <i class="bi bi-calendar-event text-xl text-indigo-600"></i>
        </div>
        <div>
            <p class="text-2xl font-bold text-zinc-900">{{ events|length }}</p>
            <p class="text-sm text-zinc-500">Total Events</p>
        </div>
    </div>
    <div class="rounded-xl border border-zinc-200 bg-white shadow-sm p-5 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center shrink-0">
            <i class="bi bi-ticket text-xl text-green-600"></i>
        </div>
        <div>
            <p class="text-2xl font-bold text-zinc-900">{{ total_reservations }}</p>
            <p class="text-sm text-zinc-500">Total Reservations</p>
        </div>
    </div>
    <div class="rounded-xl border border-zinc-200 bg-white shadow-sm p-5 flex items-center gap-4">
        <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center shrink-0">
            <i class="bi bi-people text-xl text-amber-600"></i>
        </div>
        <div>
            <p class="text-2xl font-bold text-zinc-900">{{ total_available }}</p>
            <p class="text-sm text-zinc-500">Seats Available</p>
        </div>
    </div>
</div>

{# Events table #}
{% if events is empty %}
<div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-zinc-300 bg-white py-20 text-zinc-400">
    <i class="bi bi-calendar-x text-5xl mb-4"></i>
    <p class="text-base font-medium">No events yet</p>
    <a href="{{ path('app_admin_event_new') }}" class="mt-3 text-sm font-medium text-indigo-600 hover:text-indigo-700">Create your first event →</a>
</div>
{% else %}
<div class="rounded-xl border border-zinc-200 bg-white shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-zinc-200 bg-zinc-50">
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide">#</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide">Title</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide hidden md:table-cell">Date</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide hidden lg:table-cell">Location</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide">Seats</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide">Reservations</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-zinc-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100">
                {% for event in events %}
                <tr class="hover:bg-zinc-50 transition-colors">
                    <td class="px-4 py-3.5 text-zinc-400 font-mono text-xs">{{ event.id }}</td>
                    <td class="px-4 py-3.5 font-medium text-zinc-900 max-w-[180px] truncate">{{ event.title }}</td>
                    <td class="px-4 py-3.5 text-zinc-500 whitespace-nowrap hidden md:table-cell">{{ event.date|date('d M Y, H:i') }}</td>
                    <td class="px-4 py-3.5 text-zinc-500 hidden lg:table-cell">{{ event.location }}</td>
                    <td class="px-4 py-3.5 text-zinc-500">{{ event.seats }}</td>
                    <td class="px-4 py-3.5">
                        <a href="{{ path('app_admin_event_reservations', {'id': event.id}) }}"
                           class="inline-flex items-center gap-1 rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-700 hover:bg-indigo-200 transition-colors">
                            <i class="bi bi-people"></i> {{ event.reservations|length }}
                        </a>
                    </td>
                    <td class="px-4 py-3.5">
                        <div class="flex items-center justify-end gap-1">
                            <a href="{{ path('app_event_show', {'id': event.id}) }}"
                               class="w-8 h-8 flex items-center justify-center rounded-md border border-zinc-200 text-zinc-500 hover:text-indigo-600 hover:border-indigo-200 hover:bg-indigo-50 transition-colors"
                               title="View">
                                <i class="bi bi-eye text-sm"></i>
                            </a>
                            <a href="{{ path('app_admin_event_edit', {'id': event.id}) }}"
                               class="w-8 h-8 flex items-center justify-center rounded-md border border-zinc-200 text-zinc-500 hover:text-amber-600 hover:border-amber-200 hover:bg-amber-50 transition-colors"
                               title="Edit">
                                <i class="bi bi-pencil text-sm"></i>
                            </a>
                            <form method="post" action="{{ path('app_admin_event_delete', {'id': event.id}) }}"
                                  onsubmit="return confirm('Delete this event?');" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                                <button type="submit"
                                        class="w-8 h-8 flex items-center justify-center rounded-md border border-zinc-200 text-zinc-500 hover:text-red-600 hover:border-red-200 hover:bg-red-50 transition-colors"
                                        title="Delete">
                                    <i class="bi bi-trash text-sm"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
