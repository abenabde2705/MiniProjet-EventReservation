{% extends 'base.html.twig' %}

{% block title %}EventReserve - Upcoming Events{% endblock %}

{% block body %}
<div class="hero text-center py-5 mb-4" style="background: linear-gradient(135deg,#4f46e5,#7c3aed); border-radius:16px; color:#fff;">
    <h1 class="display-5 fw-bold">Discover & Reserve Events</h1>
    <p class="lead mb-4">Find amazing events near you and book your spot in seconds.</p>
    <a href="{{ path('app_event_index') }}" class="btn btn-light btn-lg px-5">
        <i class="bi bi-search"></i> Browse All Events
    </a>
</div>

{% if events is empty %}
<div class="text-center text-muted py-5">
    <i class="bi bi-calendar-x" style="font-size:3rem;"></i>
    <p class="mt-3">No upcoming events at the moment. Check back soon!</p>
</div>
{% else %}
<h2 class="mb-4 fw-bold">Upcoming Events</h2>
<div class="row g-4">
    {% for event in events %}
    <div class="col-md-6 col-lg-4">
        <div class="card event-card h-100 shadow-sm">
            {% if event.image %}
            <img src="{{ asset('uploads/events/' ~ event.image) }}" class="card-img-top" alt="{{ event.title }}">
            {% else %}
            <div class="bg-gradient d-flex align-items-center justify-content-center" style="height:200px;background:linear-gradient(135deg,#6366f1,#8b5cf6);">
                <i class="bi bi-calendar-event text-white" style="font-size:3rem;"></i>
            </div>
            {% endif %}
            <div class="card-body d-flex flex-column">
                <h5 class="card-title fw-bold">{{ event.title }}</h5>
                <p class="text-muted small mb-1">
                    <i class="bi bi-calendar3"></i> {{ event.date|date('d M Y, H:i') }}
                </p>
                <p class="text-muted small mb-2">
                    <i class="bi bi-geo-alt"></i> {{ event.location }}
                </p>
                <p class="card-text text-muted flex-grow-1">{{ event.description|slice(0, 100) }}{% if event.description|length > 100 %}...{% endif %}</p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="badge bg-success">{{ event.availableSeats }} seats left</span>
                    <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-primary btn-sm">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
