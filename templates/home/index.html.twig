{% extends 'base.html.twig' %}

{% block title %}EventReserve - Upcoming Events{% endblock %}

{% block body %}
{# ── Hero ── #}
<div class="relative rounded-2xl overflow-hidden mb-10 bg-gradient-to-br from-indigo-600 via-indigo-700 to-violet-800 px-8 py-16 text-center text-white shadow-lg">
    <div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml;base64,')]"></div>
    <div class="relative">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-white/20 px-3 py-1 text-xs font-medium text-white/90 mb-4">
            <i class="bi bi-stars"></i> Discover amazing events
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4 tracking-tight">Discover & Reserve Events</h1>
        <p class="text-lg text-indigo-100 mb-8 max-w-xl mx-auto">Find amazing events near you and book your spot in seconds.</p>
        <a href="{{ path('app_event_index') }}" class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-indigo-700 hover:bg-indigo-50 transition-colors shadow-sm">
            <i class="bi bi-search"></i> Browse All Events
        </a>
    </div>
</div>

{# ── Events ── #}
{% if events is empty %}
<div class="flex flex-col items-center justify-center py-20 text-zinc-400">
    <i class="bi bi-calendar-x text-5xl mb-4"></i>
    <p class="text-base">No upcoming events at the moment. Check back soon!</p>
</div>
{% else %}
<div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-zinc-900">Upcoming Events</h2>
    <a href="{{ path('app_event_index') }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-700 transition-colors">
        View all <i class="bi bi-arrow-right"></i>
    </a>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {% for event in events %}
    <div class="group rounded-xl border border-zinc-200 bg-white shadow-sm overflow-hidden hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col">
        {% if event.image %}
        <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-full h-48 object-cover" alt="{{ event.title }}">
        {% else %}
        <div class="w-full h-48 bg-gradient-to-br from-indigo-400 to-violet-500 flex items-center justify-center">
            <i class="bi bi-calendar-event text-white text-5xl opacity-70"></i>
        </div>
        {% endif %}
        <div class="p-5 flex flex-col flex-1">
            <h3 class="font-semibold text-zinc-900 mb-2 line-clamp-1">{{ event.title }}</h3>
            <div class="flex items-center gap-1.5 text-xs text-zinc-500 mb-1">
                <i class="bi bi-calendar3 text-indigo-500"></i>
                {{ event.date|date('d M Y, H:i') }}
            </div>
            <div class="flex items-center gap-1.5 text-xs text-zinc-500 mb-3">
                <i class="bi bi-geo-alt text-indigo-500"></i>
                {{ event.location }}
            </div>
            <p class="text-sm text-zinc-500 flex-1 mb-4">{{ event.description|slice(0, 100) }}{% if event.description|length > 100 %}…{% endif %}</p>
            <div class="flex items-center justify-between pt-3 border-t border-zinc-100">
                {% if event.availableSeats > 0 %}
                <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">
                    <i class="bi bi-people"></i> {{ event.availableSeats }} seats left
                </span>
                {% else %}
                <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-700">Fully Booked</span>
                {% endif %}
                <a href="{{ path('app_event_show', {'id': event.id}) }}" class="inline-flex items-center gap-1 rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-indigo-700 transition-colors">
                    View Details <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
