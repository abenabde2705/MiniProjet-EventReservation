{% extends 'base.html.twig' %}

{% block title %}My Reservations - EventReserve{% endblock %}

{% block body %}
<div class="mb-8">
    <h1 class="text-2xl font-bold text-zinc-900">My Reservations</h1>
    <p class="text-sm text-zinc-500 mt-1">All events you have reserved</p>
</div>

{% if reservations is empty %}
<div class="flex flex-col items-center justify-center rounded-xl border border-dashed border-zinc-300 bg-white py-20 text-zinc-400">
    <i class="bi bi-ticket-x text-5xl mb-4"></i>
    <p class="text-base font-medium">No reservations yet</p>
    <p class="text-sm mt-1 mb-6">Browse events and book your first seat!</p>
    <a href="{{ path('app_event_index') }}"
       class="inline-flex items-center gap-2 rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition-colors">
        <i class="bi bi-search"></i> Browse Events
    </a>
</div>
{% else %}
<div class="rounded-xl border border-zinc-200 bg-white shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-zinc-200 bg-zinc-50">
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide">Event</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide">Date</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide hidden md:table-cell">Location</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide hidden sm:table-cell">Booked On</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-zinc-500 uppercase tracking-wide">Ref</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-zinc-100">
                {% for res in reservations %}
                <tr class="hover:bg-zinc-50 transition-colors">
                    <td class="px-4 py-3.5 font-medium text-zinc-900">
                        <a href="{{ path('app_event_show', {'id': res.event.id}) }}"
                           class="hover:text-indigo-600 transition-colors">
                            {{ res.event.title }}
                        </a>
                    </td>
                    <td class="px-4 py-3.5 text-zinc-500 whitespace-nowrap">{{ res.event.date|date('d M Y, H:i') }}</td>
                    <td class="px-4 py-3.5 text-zinc-500 hidden md:table-cell">{{ res.event.location }}</td>
                    <td class="px-4 py-3.5 text-zinc-500 hidden sm:table-cell whitespace-nowrap">{{ res.createdAt|date('d M Y') }}</td>
                    <td class="px-4 py-3.5">
                        <span class="font-mono text-xs bg-zinc-100 text-zinc-600 px-2 py-0.5 rounded">#{{ res.id }}</span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
