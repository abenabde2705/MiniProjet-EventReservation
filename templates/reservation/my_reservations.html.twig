{% extends 'base.html.twig' %}

{% block title %}My Reservations - EventReserve{% endblock %}

{% block body %}
<h1 class="fw-bold mb-4"><i class="bi bi-ticket"></i> My Reservations</h1>

{% if reservations is empty %}
<div class="text-center text-muted py-5">
    <i class="bi bi-ticket-x" style="font-size:3rem;"></i>
    <p class="mt-3">You have no reservations yet.</p>
    <a href="{{ path('app_event_index') }}" class="btn btn-primary">Browse Events</a>
</div>
{% else %}
<div class="table-responsive">
    <table class="table table-hover align-middle bg-white shadow-sm rounded-3 overflow-hidden">
        <thead class="table-light">
            <tr>
                <th>Event</th>
                <th>Date</th>
                <th>Location</th>
                <th>Booked On</th>
                <th>Ref #</th>
            </tr>
        </thead>
        <tbody>
            {% for res in reservations %}
            <tr>
                <td class="fw-semibold">
                    <a href="{{ path('app_event_show', {'id': res.event.id}) }}">{{ res.event.title }}</a>
                </td>
                <td>{{ res.event.date|date('d M Y, H:i') }}</td>
                <td>{{ res.event.location }}</td>
                <td>{{ res.createdAt|date('d M Y') }}</td>
                <td><code>#{{ res.id }}</code></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}
{% endblock %}
