{% extends 'base.html.twig' %}

{% block title %}Reservation Confirmed!{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6 text-center">
        <div class="card border-0 shadow-sm rounded-3 p-5">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size:5rem;"></i>
            </div>
            <h1 class="fw-bold text-success mb-2">Reservation Confirmed!</h1>
            <p class="lead text-muted mb-4">
                Thank you, <strong>{{ reservation.name }}</strong>! Your seat has been reserved.
            </p>

            <div class="card bg-light border-0 rounded-3 p-4 text-start mb-4">
                <h5 class="fw-bold mb-3">Reservation Details</h5>
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted">Event</td>
                        <td class="fw-semibold">{{ reservation.event.title }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Date</td>
                        <td>{{ reservation.event.date|date('d M Y, H:i') }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Location</td>
                        <td>{{ reservation.event.location }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Name</td>
                        <td>{{ reservation.name }}</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Email</td>
                        <td>{{ reservation.email }}</td>
                    </tr>
                    {% if reservation.phone %}
                    <tr>
                        <td class="text-muted">Phone</td>
                        <td>{{ reservation.phone }}</td>
                    </tr>
                    {% endif %}
                    <tr>
                        <td class="text-muted">Ref #</td>
                        <td><code>#{{ reservation.id }}</code></td>
                    </tr>
                </table>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a href="{{ path('app_event_index') }}" class="btn btn-outline-primary">
                    <i class="bi bi-grid"></i> Browse More Events
                </a>
                <a href="{{ path('app_reservation_my_reservations') }}" class="btn btn-primary">
                    <i class="bi bi-ticket"></i> My Reservations
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
