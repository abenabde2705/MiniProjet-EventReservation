{% extends 'base.html.twig' %}

{% block title %}Reservation Confirmed!{% endblock %}

{% block body %}
<div class="flex items-center justify-center py-8">
    <div class="w-full max-w-lg">
        <div class="rounded-xl border border-zinc-200 bg-white shadow-sm overflow-hidden">
            {# Success header #}
            <div class="bg-gradient-to-r from-green-500 to-emerald-600 px-6 py-8 text-center text-white">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/20 mb-4">
                    <i class="bi bi-check-lg text-3xl"></i>
                </div>
                <h1 class="text-2xl font-bold mb-1">Reservation Confirmed!</h1>
                <p class="text-green-100 text-sm">Thank you, <strong>{{ reservation.name }}</strong>! Your seat has been reserved.</p>
            </div>

            {# Details #}
            <div class="p-6">
                <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wide mb-4">Reservation Details</h2>
                <dl class="space-y-3">
                    <div class="flex justify-between items-start text-sm">
                        <dt class="text-zinc-500 shrink-0 w-28">Event</dt>
                        <dd class="font-semibold text-zinc-900 text-right">{{ reservation.event.title }}</dd>
                    </div>
                    <div class="flex justify-between items-start text-sm border-t border-zinc-100 pt-3">
                        <dt class="text-zinc-500 shrink-0 w-28">Date</dt>
                        <dd class="text-zinc-700 text-right">{{ reservation.event.date|date('d M Y, H:i') }}</dd>
                    </div>
                    <div class="flex justify-between items-start text-sm border-t border-zinc-100 pt-3">
                        <dt class="text-zinc-500 shrink-0 w-28">Location</dt>
                        <dd class="text-zinc-700 text-right">{{ reservation.event.location }}</dd>
                    </div>
                    <div class="flex justify-between items-start text-sm border-t border-zinc-100 pt-3">
                        <dt class="text-zinc-500 shrink-0 w-28">Name</dt>
                        <dd class="text-zinc-700 text-right">{{ reservation.name }}</dd>
                    </div>
                    <div class="flex justify-between items-start text-sm border-t border-zinc-100 pt-3">
                        <dt class="text-zinc-500 shrink-0 w-28">Email</dt>
                        <dd class="text-zinc-700 text-right">{{ reservation.email }}</dd>
                    </div>
                    {% if reservation.phone %}
                    <div class="flex justify-between items-start text-sm border-t border-zinc-100 pt-3">
                        <dt class="text-zinc-500 shrink-0 w-28">Phone</dt>
                        <dd class="text-zinc-700 text-right">{{ reservation.phone }}</dd>
                    </div>
                    {% endif %}
                    <div class="flex justify-between items-start text-sm border-t border-zinc-100 pt-3">
                        <dt class="text-zinc-500 shrink-0 w-28">Reference</dt>
                        <dd class="font-mono text-xs bg-zinc-100 text-zinc-700 px-2 py-1 rounded">#{{ reservation.id }}</dd>
                    </div>
                </dl>
            </div>

            {# Actions #}
            <div class="px-6 pb-6 flex flex-col sm:flex-row gap-3">
                <a href="{{ path('app_event_index') }}"
                   class="flex-1 flex items-center justify-center gap-2 rounded-md border border-zinc-200 bg-white px-4 py-2.5 text-sm font-medium text-zinc-700 hover:bg-zinc-50 transition-colors">
                    <i class="bi bi-grid"></i> Browse Events
                </a>
                <a href="{{ path('app_reservation_my_reservations') }}"
                   class="flex-1 flex items-center justify-center gap-2 rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-700 transition-colors">
                    <i class="bi bi-ticket"></i> My Reservations
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
