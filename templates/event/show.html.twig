{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - EventReserve{% endblock %}

{% block body %}
{# Breadcrumb #}
<nav class="flex items-center gap-1.5 text-sm text-zinc-500 mb-6">
    <a href="{{ path('app_home') }}" class="hover:text-zinc-900 transition-colors">Home</a>
    <i class="bi bi-chevron-right text-xs text-zinc-400"></i>
    <a href="{{ path('app_event_index') }}" class="hover:text-zinc-900 transition-colors">Events</a>
    <i class="bi bi-chevron-right text-xs text-zinc-400"></i>
    <span class="text-zinc-900 font-medium truncate max-w-xs">{{ event.title }}</span>
</nav>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    {# Main content #}
    <div class="lg:col-span-2">
        {% if event.image %}
        <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}"
             class="w-full h-72 sm:h-96 object-cover rounded-xl mb-6 shadow-sm">
        {% else %}
        <div class="w-full h-72 sm:h-80 rounded-xl mb-6 bg-gradient-to-br from-indigo-400 to-violet-500 flex items-center justify-center shadow-sm">
            <i class="bi bi-calendar-event text-white text-7xl opacity-70"></i>
        </div>
        {% endif %}

        <h1 class="text-3xl font-bold text-zinc-900 mb-4">{{ event.title }}</h1>
        <p class="text-zinc-600 leading-relaxed whitespace-pre-wrap">{{ event.description }}</p>
    </div>

    {# Sidebar #}
    <div class="lg:col-span-1">
        <div class="sticky top-24 rounded-xl border border-zinc-200 bg-white shadow-sm p-6">
            <h2 class="font-semibold text-zinc-900 mb-4">Event Details</h2>

            <ul class="space-y-3 mb-6">
                <li class="flex items-start gap-3 text-sm">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0">
                        <i class="bi bi-calendar3 text-indigo-600"></i>
                    </span>
                    <div>
                        <p class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-0.5">Date</p>
                        <p class="text-zinc-700 font-medium">{{ event.date|date('l, d F Y') }}</p>
                    </div>
                </li>
                <li class="flex items-start gap-3 text-sm">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0">
                        <i class="bi bi-clock text-indigo-600"></i>
                    </span>
                    <div>
                        <p class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-0.5">Time</p>
                        <p class="text-zinc-700 font-medium">{{ event.date|date('H:i') }}</p>
                    </div>
                </li>
                <li class="flex items-start gap-3 text-sm">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0">
                        <i class="bi bi-geo-alt text-indigo-600"></i>
                    </span>
                    <div>
                        <p class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-0.5">Location</p>
                        <p class="text-zinc-700 font-medium">{{ event.location }}</p>
                    </div>
                </li>
                <li class="flex items-start gap-3 text-sm">
                    <span class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0">
                        <i class="bi bi-people text-indigo-600"></i>
                    </span>
                    <div>
                        <p class="text-xs text-zinc-400 font-medium uppercase tracking-wide mb-0.5">Availability</p>
                        {% if event.availableSeats > 0 %}
                        <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">
                            <i class="bi bi-check-circle"></i> {{ event.availableSeats }} seats available
                        </span>
                        {% else %}
                        <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-700">Fully Booked</span>
                        {% endif %}
                    </div>
                </li>
            </ul>

            <div class="border-t border-zinc-100 pt-5">
                {% if app.user %}
                    {% if event.availableSeats > 0 %}
                    <a href="{{ path('app_reservation_create', {'id': event.id}) }}"
                       class="w-full flex items-center justify-center gap-2 rounded-md bg-indigo-600 px-4 py-3 text-sm font-semibold text-white hover:bg-indigo-700 transition-colors shadow-sm">
                        <i class="bi bi-ticket-perforated"></i> Reserve a Seat
                    </a>
                    {% else %}
                    <button disabled
                            class="w-full flex items-center justify-center gap-2 rounded-md bg-zinc-100 px-4 py-3 text-sm font-semibold text-zinc-400 cursor-not-allowed">
                        Fully Booked
                    </button>
                    {% endif %}
                {% else %}
                <a href="{{ path('app_login') }}"
                   class="w-full flex items-center justify-center gap-2 rounded-md border border-indigo-200 bg-indigo-50 px-4 py-3 text-sm font-semibold text-indigo-700 hover:bg-indigo-100 transition-colors">
                    <i class="bi bi-box-arrow-in-right"></i> Login to Reserve
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
