{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} - EventReserve{% endblock %}

{% block body %}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
        <li class="breadcrumb-item"><a href="{{ path('app_event_index') }}">Events</a></li>
        <li class="breadcrumb-item active">{{ event.title }}</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-lg-8">
        {% if event.image %}
        <img src="{{ asset('uploads/events/' ~ event.image) }}" class="img-fluid rounded-3 mb-4 w-100" alt="{{ event.title }}" style="max-height:400px;object-fit:cover;">
        {% else %}
        <div class="rounded-3 mb-4 d-flex align-items-center justify-content-center" style="height:300px;background:linear-gradient(135deg,#6366f1,#8b5cf6);">
            <i class="bi bi-calendar-event text-white" style="font-size:5rem;"></i>
        </div>
        {% endif %}

        <h1 class="fw-bold mb-3">{{ event.title }}</h1>
        <p class="text-muted" style="white-space:pre-wrap;">{{ event.description }}</p>
    </div>

    <div class="col-lg-4">
        <div class="card shadow border-0 sticky-top" style="top:20px;">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Event Details</h5>

                <ul class="list-unstyled">
                    <li class="mb-2">
                        <i class="bi bi-calendar3 text-primary me-2"></i>
                        <strong>Date:</strong> {{ event.date|date('l, d F Y') }}
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-clock text-primary me-2"></i>
                        <strong>Time:</strong> {{ event.date|date('H:i') }}
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-geo-alt text-primary me-2"></i>
                        <strong>Location:</strong> {{ event.location }}
                    </li>
                    <li class="mb-3">
                        <i class="bi bi-people text-primary me-2"></i>
                        <strong>Seats:</strong>
                        {% if event.availableSeats > 0 %}
                        <span class="badge bg-success">{{ event.availableSeats }} available</span>
                        {% else %}
                        <span class="badge bg-danger">Fully Booked</span>
                        {% endif %}
                    </li>
                </ul>

                {% if app.user %}
                    {% if event.availableSeats > 0 %}
                    <a href="{{ path('app_reservation_create', {'id': event.id}) }}" class="btn btn-primary w-100 btn-lg">
                        <i class="bi bi-ticket-perforated"></i> Reserve a Seat
                    </a>
                    {% else %}
                    <button class="btn btn-secondary w-100 btn-lg" disabled>Fully Booked</button>
                    {% endif %}
                {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-outline-primary w-100 btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Login to Reserve
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
