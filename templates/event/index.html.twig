{% extends 'base.html.twig' %}

{% block title %}All Events - EventReserve{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold"><i class="bi bi-grid"></i> All Events</h1>
</div>

{% if events is empty %}
<div class="text-center text-muted py-5">
    <i class="bi bi-calendar-x" style="font-size:3rem;"></i>
    <p class="mt-3">No events found.</p>
</div>
{% else %}
<div class="row g-4">
    {% for event in events %}
    <div class="col-md-6 col-lg-4">
        <div class="card event-card h-100 shadow-sm">
            {% if event.image %}
            <img src="{{ asset('uploads/events/' ~ event.image) }}" class="card-img-top" alt="{{ event.title }}">
            {% else %}
            <div class="d-flex align-items-center justify-content-center" style="height:200px;background:linear-gradient(135deg,#6366f1,#8b5cf6);">
                <i class="bi bi-calendar-event text-white" style="font-size:3rem;"></i>
            </div>
            {% endif %}
            <div class="card-body d-flex flex-column">
                <h5 class="card-title fw-bold">{{ event.title }}</h5>
                <p class="text-muted small mb-1">
                    <i class="bi bi-calendar3"></i> {{ event.date|date('d M Y, H:i') }}
                </p>
                <p class="text-muted small mb-2">
                    <i class="bi bi-geo-alt"></i> {{ event.location }}
                </p>
                <p class="card-text text-muted flex-grow-1">
                    {{ event.description|slice(0, 120) }}{% if event.description|length > 120 %}...{% endif %}
                </p>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    {% if event.availableSeats > 0 %}
                    <span class="badge bg-success"><i class="bi bi-people"></i> {{ event.availableSeats }} seats</span>
                    {% else %}
                    <span class="badge bg-danger">Fully Booked</span>
                    {% endif %}
                    <a href="{{ path('app_event_show', {'id': event.id}) }}" class="btn btn-primary btn-sm">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
