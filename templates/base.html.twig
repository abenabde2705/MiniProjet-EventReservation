<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EventReserve{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🎫</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
            },
          }
        }
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
      body { font-family: 'Inter', sans-serif; }
      .dropdown:focus-within .dropdown-menu { display: block; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="min-h-screen bg-zinc-50 text-zinc-900 antialiased flex flex-col">

{# ── Navbar ── #}
<header class="sticky top-0 z-50 w-full border-b border-zinc-200 bg-white/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex h-16 items-center justify-between">

        {# Left: logo + nav links #}
        <div class="flex items-center gap-8">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2 text-xl font-bold text-indigo-600 hover:text-indigo-700 transition-colors">
                <i class="bi bi-calendar-event"></i>
                <span>EventReserve</span>
            </a>
            <nav class="hidden md:flex items-center gap-1">
                <a href="{{ path('app_event_index') }}" class="flex items-center gap-1.5 px-3 py-2 rounded-md text-sm font-medium text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100 transition-colors">
                    <i class="bi bi-grid-3x3-gap"></i> Events
                </a>
                {% if app.user %}
                <a href="{{ path('app_reservation_my_reservations') }}" class="flex items-center gap-1.5 px-3 py-2 rounded-md text-sm font-medium text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100 transition-colors">
                    <i class="bi bi-ticket"></i> My Reservations
                </a>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_admin_dashboard') }}" class="flex items-center gap-1.5 px-3 py-2 rounded-md text-sm font-medium text-red-600 hover:text-red-700 hover:bg-red-50 transition-colors">
                    <i class="bi bi-speedometer2"></i> Admin
                </a>
                {% endif %}
            </nav>
        </div>

        {# Right: auth #}
        <div class="flex items-center gap-2">
            {% if app.user %}
            <div class="dropdown relative">
                <button class="flex items-center gap-2 px-3 py-2 rounded-md text-sm font-medium text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100 transition-colors cursor-pointer">
                    <span class="w-7 h-7 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold">
                        {{ app.user.userIdentifier|slice(0,1)|upper }}
                    </span>
                    <span class="hidden sm:inline">{{ app.user.userIdentifier }}</span>
                    <i class="bi bi-chevron-down text-xs opacity-60"></i>
                </button>
                <div class="dropdown-menu hidden absolute right-0 mt-1 w-44 rounded-lg border border-zinc-200 bg-white shadow-lg py-1 z-50">
                    <div class="px-3 py-2 border-b border-zinc-100">
                        <p class="text-xs text-zinc-500">Signed in as</p>
                        <p class="text-sm font-medium truncate">{{ app.user.userIdentifier }}</p>
                    </div>
                    <a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-3 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
            {% else %}
            <a href="{{ path('app_login') }}" class="px-3 py-2 rounded-md text-sm font-medium text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100 transition-colors">
                Sign in
            </a>
            <a href="{{ path('app_register') }}" class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition-colors shadow-sm">
                Get Started
            </a>
            {% endif %}
        </div>
    </div>
</header>

{# ── Main ── #}
<main class="flex-1 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
            <div class="mb-4 flex items-start gap-3 rounded-lg border px-4 py-3 text-sm
                {% if type == 'success' %}border-green-200 bg-green-50 text-green-800
                {% elseif type == 'error' or type == 'danger' %}border-red-200 bg-red-50 text-red-800
                {% elseif type == 'warning' %}border-yellow-200 bg-yellow-50 text-yellow-800
                {% else %}border-blue-200 bg-blue-50 text-blue-800{% endif %}">
                <i class="bi bi-{% if type == 'success' %}check-circle-fill{% elseif type == 'error' or type == 'danger' %}exclamation-triangle-fill{% elseif type == 'warning' %}exclamation-circle-fill{% else %}info-circle-fill{% endif %} mt-0.5 shrink-0"></i>
                <span>{{ message }}</span>
            </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </div>
</main>

{# ── Footer ── #}
<footer class="border-t border-zinc-200 bg-zinc-900 py-6 mt-auto">
    <div class="max-w-7xl mx-auto px-4 text-center">
        <p class="text-sm text-zinc-400">&copy; {{ "now"|date("Y") }} EventReserve &mdash; Gestion de Réservations d'Événements</p>
    </div>
</footer>

<script>
  // Dropdown toggle
  document.querySelectorAll('.dropdown button').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const menu = btn.nextElementSibling;
      menu.classList.toggle('hidden');
    });
  });
  document.addEventListener('click', () => {
    document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('hidden'));
  });
</script>

{% block javascripts %}{% endblock %}
</body>
</html>
